# Copy this file to ".env" and fill in the actual values
# Do NOT commit your real credentials or API keys.

# Application
APP_NAME="Your App Name"
APP_ENV=development
DEBUG=true
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=5005

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>

# Redis
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Model Server (Modal-deployed via proxy on port 5007)
MODEL_SERVER_URL=http://localhost:5007
MODEL_NAME=sri-legal-8b

# Embedding (Gemini for embedding only + sentence-transformers backup)
GEMINI_API_KEY=
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=3072
EMBEDDING_BATCH_SIZE=100
USE_SENTENCE_TRANSFORMERS_BACKUP=true
ST_EMBEDDING_MODEL=all-MiniLM-L6-v2
ST_EMBEDDING_DIMENSION=384

# FAISS Index
FAISS_INDEX_PATH=./models/faiss_index/index.faiss
FAISS_DOCUMENTS_PATH=./models/faiss_index/documents.pkl
FAISS_PARTITIONS_PATH=./models/faiss_partitions
FAISS_TOP_K=15
FAISS_MIN_SIMILARITY=0.3

# RAG
RAG_MAX_CONTEXT_LENGTH=8000
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150

# Query Validation
QUERY_MIN_LENGTH=10
QUERY_MAX_LENGTH=2000

# Document Processing
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=["application/pdf","text/plain"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
